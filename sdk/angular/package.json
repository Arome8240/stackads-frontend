{
  "name": "@stackads/angular",
  "version": "0.1.0",
  "description": "Angular services for StackAds platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "stackads",
    "angular",
    "stacks",
    "blockchain",
    "advertising",
    "rxjs"
  ],
  "author": "StackAds Team",
  "license": "MIT",
  "peerDependencies": {
    "@angular/core": "^17.0.0 || ^18.0.0",
    "rxjs": "^7.8.0",
    "@stacks/connect": "^7.0.0",
    "@stacks/transactions": "^6.0.0"
  },
  "dependencies": {
    "@stackads/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "@angular/core": "^18.0.0",
    "@types/node": "^20.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
