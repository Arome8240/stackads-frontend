{
  "name": "@stackads/sdk-core",
  "version": "0.1.0",
  "description": "Core SDK for StackAds - Interact with Stacks smart contracts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "stackads",
    "stacks",
    "blockchain",
    "advertising",
    "web3",
    "clarity"
  ],
  "author": "StackAds Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stackads/stackads-sdk"
  },
  "dependencies": {
    "@stacks/connect": "^7.8.2",
    "@stacks/network": "^6.13.0",
    "@stacks/transactions": "^6.13.0",
    "@stacks/stacks-blockchain-api-types": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "@stacks/connect": ">=7.0.0",
    "@stacks/network": ">=6.0.0",
    "@stacks/transactions": ">=6.0.0"
  }
}
