{
  "name": "@stackads/vanilla",
  "version": "0.1.0",
  "description": "Vanilla JavaScript SDK for StackAds platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.global.js",
  "jsdelivr": "dist/index.global.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name StackAds --dts",
    "dev": "tsup src/index.ts --format cjs,esm,iife --global-name StackAds --dts --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "stackads",
    "vanilla",
    "javascript",
    "stacks",
    "blockchain",
    "advertising"
  ],
  "author": "StackAds Team",
  "license": "MIT",
  "peerDependencies": {
    "@stacks/connect": "^7.0.0",
    "@stacks/transactions": "^6.0.0"
  },
  "dependencies": {
    "@stackads/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
