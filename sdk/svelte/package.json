{
  "name": "@stackads/svelte",
  "version": "0.1.0",
  "description": "Svelte stores for StackAds platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "svelte": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "stackads",
    "svelte",
    "stores",
    "stacks",
    "blockchain",
    "advertising"
  ],
  "author": "StackAds Team",
  "license": "MIT",
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0",
    "@stacks/connect": "^7.0.0",
    "@stacks/transactions": "^6.0.0"
  },
  "dependencies": {
    "@stackads/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "svelte": "^4.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
