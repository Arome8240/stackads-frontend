{
  "name": "@stackads/react",
  "version": "0.1.0",
  "description": "React hooks for StackAds SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "stackads",
    "react",
    "hooks",
    "stacks",
    "blockchain",
    "web3"
  ],
  "author": "StackAds Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stackads/stackads-sdk"
  },
  "dependencies": {
    "@stackads/sdk-core": "workspace:*",
    "@stacks/connect-react": "^21.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/node": "^20.11.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@stacks/connect-react": ">=21.0.0"
  }
}
