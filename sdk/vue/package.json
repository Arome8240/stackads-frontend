{
  "name": "@stackads/vue",
  "version": "0.1.0",
  "description": "Vue 3 composables for StackAds platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts,.vue",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "stackads",
    "vue",
    "vue3",
    "composables",
    "stacks",
    "blockchain",
    "advertising"
  ],
  "author": "StackAds Team",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0",
    "@stacks/connect": "^7.0.0",
    "@stacks/transactions": "^6.0.0"
  },
  "dependencies": {
    "@stackads/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vue": "^3.3.0"
  }
}
